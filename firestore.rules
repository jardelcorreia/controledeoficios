
rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Permite leitura e escrita autenticada para ofícios, histórico e configurações
    match /oficios/{oficioId} {
      allow read, write: if request.auth != null;
    }

    match /historico/{historicoId} {
      allow read, write: if request.auth != null;
    }

    match /config/{configId} {
      allow read, write: if request.auth != null;
    }

    // Permite que qualquer pessoa crie uma inscrição de push.
    // Isso é seguro porque o token só pode ser gerado pelo próprio dispositivo do usuário.
    match /pushSubscriptions/{subscriptionId} {
      allow read, create, update: if true;
    }
  }
}
