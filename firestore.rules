rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // Oficios: Apenas usuários autenticados podem ler e escrever.
    match /oficios/{oficioId} {
      allow read, write: if request.auth != null;
    }

    // Histórico: Apenas usuários autenticados podem ler. A escrita é feita pelo servidor.
    match /historico/{historicoId} {
      allow read: if request.auth != null;
      allow write: if false; // Bloqueia escrita direta pelo cliente
    }

    // Config: Permite a leitura pública da configuração de numeração,
    // mas apenas usuários autenticados podem alterá-la.
    match /config/{configId} {
      allow read: if true;
      allow write: if request.auth != null;
    }
    
    // Push Subscriptions: Permite que qualquer cliente crie uma inscrição.
    // Isso é necessário para o processo de registro do token de notificação.
    match /pushSubscriptions/{subscriptionId} {
      allow create: if true;
      allow read, update, delete: if request.auth != null; // Apenas autenticados para outras operações
    }
  }
}
