rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
  
    // As regras de escrita para estas coleções são gerenciadas
    // por Cloud Functions e Server Actions. Clientes não devem escrever diretamente.
    match /oficios/{document=**} {
      allow read: if true;
      allow write: if false;
    }

    match /historico/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    
    match /config/{document=**} {
      allow read: if true;
      allow write: if false;
    }
    
    // Permite que qualquer cliente crie ou atualize sua própria inscrição de push.
    // Usar o token como ID do documento (subscriptionId) é uma boa prática
    // para evitar duplicatas. A regra permite que um cliente crie um novo
    // documento ou sobrescreva um existente se o ID for o mesmo.
    match /pushSubscriptions/{subscriptionId} {
      allow create, update: if true;
      allow read, delete: if false; // Apenas o servidor deve ler/deletar
    }
  }
}
