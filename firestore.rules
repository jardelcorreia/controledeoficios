rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Permite acesso público total a todas as coleções, já que
    // o aplicativo não possui sistema de autenticação no momento.
    
    match /oficios/{oficioId} {
      allow read, write, delete: if true;
    }

    match /historico/{docId} {
      allow read, write: if true;
    }
    
    match /config/{docId} {
      allow read, write: if true;
    }
    
    match /pushSubscriptions/{docId} {
      allow read, write: if true;
    }
  }
}
